diff --git a/src/ggml-webgpu/wgsl-shaders/upscale.wgsl b/src/ggml-webgpu/wgsl-shaders/upscale.wgsl
new file mode 100644
index 0000000..765df22
--- /dev/null
+++ b/src/ggml-webgpu/wgsl-shaders/upscale.wgsl
@@ -0,0 +1,89 @@
+// upscale / interpolate: src [IW, IH, C, N] f32 -> dst [OW, OH, C, N] f32
+// (contiguous dst). Variants: NEAREST / BILINEAR — element-exact ports of
+// the CPU reference (pixel_offset convention, edge clamping). Scale factors
+// and pixel_offset are computed host-side (incl. align-corners). 2D dispatch.
+
+@group(0) @binding(0)
+var<storage, read_write> src: array<f32>;
+
+@group(0) @binding(1)
+var<storage, read_write> dst: array<f32>;
+
+struct Params {
+    ne: u32,
+    nwg_x: u32,
+    offset_src: u32,
+    offset_dst: u32,
+
+    // src strides (in elements)
+    stride_src0: u32,
+    stride_src1: u32,
+    stride_src2: u32,
+    stride_src3: u32,
+
+    IW: u32,
+    IH: u32,
+    OW: u32,
+    OH: u32,
+    C: u32,            // dst ne2
+
+    sf0: f32,
+    sf1: f32,
+    sf2: f32,
+    sf3: f32,
+    pixel_offset: f32,
+};
+
+@group(0) @binding(2)
+var<uniform> params: Params;
+
+@compute @workgroup_size(WG_SIZE)
+fn main(@builtin(workgroup_id) wid: vec3<u32>,
+        @builtin(local_invocation_id) lid: vec3<u32>) {
+    let idx = (wid.y * params.nwg_x + wid.x) * WG_SIZE + lid.x;
+    if (idx >= params.ne) {
+        return;
+    }
+
+    var i = idx;
+    let plane = params.OH * params.OW;
+    let i23 = i / plane;
+    i = i % plane;
+    let oy = i / params.OW;
+    let ox = i % params.OW;
+    let i3 = i23 / params.C;
+    let i2 = i23 % params.C;
+
+    let i02 = u32(f32(i2) / params.sf2);
+    let i03 = u32(f32(i3) / params.sf3);
+    let base = params.offset_src + i03 * params.stride_src3 + i02 * params.stride_src2;
+
+#ifdef NEAREST
+    let i01 = u32(f32(oy) / params.sf1);
+    let i00 = u32(f32(ox) / params.sf0);
+    dst[params.offset_dst + idx] = src[base + i01 * params.stride_src1 + i00 * params.stride_src0];
+#else
+    // BILINEAR
+    let y = (f32(oy) + params.pixel_offset) / params.sf1 - params.pixel_offset;
+    var y0 = i32(floor(y));
+    var y1 = y0 + 1;
+    y0 = clamp(y0, 0, i32(params.IH) - 1);
+    y1 = clamp(y1, 0, i32(params.IH) - 1);
+    let dy = clamp(y - f32(y0), 0.0, 1.0);
+
+    let x = (f32(ox) + params.pixel_offset) / params.sf0 - params.pixel_offset;
+    var x0 = i32(floor(x));
+    var x1 = x0 + 1;
+    x0 = clamp(x0, 0, i32(params.IW) - 1);
+    x1 = clamp(x1, 0, i32(params.IW) - 1);
+    let dx = clamp(x - f32(x0), 0.0, 1.0);
+
+    let a = src[base + u32(y0) * params.stride_src1 + u32(x0) * params.stride_src0];
+    let b = src[base + u32(y0) * params.stride_src1 + u32(x1) * params.stride_src0];
+    let c = src[base + u32(y1) * params.stride_src1 + u32(x0) * params.stride_src0];
+    let d = src[base + u32(y1) * params.stride_src1 + u32(x1) * params.stride_src0];
+
+    dst[params.offset_dst + idx] = a * (1.0 - dx) * (1.0 - dy) + b * dx * (1.0 - dy) +
+                                   c * (1.0 - dx) * dy + d * dx * dy;
+#endif
+}
