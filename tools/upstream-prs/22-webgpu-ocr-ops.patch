+    auto *          decisions = static_cast<ggml_webgpu_generic_shader_decisions *>(pipeline.context.get());
+
+    const uint32_t ne = (uint32_t) ggml_nelements(dst);
+    uint32_t       wg_x, wg_y;
+    ggml_webgpu_wg2d(ctx, CEIL_DIV(ne, decisions->wg_size), wg_x, wg_y);
+
+    std::vector<uint32_t> params = {
+        ne,
+        wg_x,
+        (uint32_t) (ggml_webgpu_tensor_misalignment(ctx, src1) / ggml_type_size(src1->type)),
+        (uint32_t) (ggml_webgpu_tensor_misalignment(ctx, dst) / ggml_type_size(dst->type)),
+        (uint32_t) (src1->nb[1] / ggml_type_size(src1->type)),
+        (uint32_t) (src1->nb[2] / ggml_type_size(src1->type)),
+        (uint32_t) (src1->nb[3] / ggml_type_size(src1->type)),
+        (uint32_t) src1->ne[0],  // IW
+        (uint32_t) src1->ne[1],  // IH
+        (uint32_t) dst->ne[1],   // OW
+        (uint32_t) dst->ne[2],   // OH
+        (uint32_t) dst->src[0]->ne[0],  // KW
+        (uint32_t) dst->src[0]->ne[1],  // KH
+        (uint32_t) dst->ne[0],   // CHW = IC*KH*KW
+        (uint32_t) ggml_get_op_params_i32(dst, 0),  // s0
+        (uint32_t) ggml_get_op_params_i32(dst, 1),  // s1
+        (uint32_t) ggml_get_op_params_i32(dst, 2),  // p0
+        (uint32_t) ggml_get_op_params_i32(dst, 3),  // p1
+        (uint32_t) ggml_get_op_params_i32(dst, 4),  // d0
+        (uint32_t) ggml_get_op_params_i32(dst, 5),  // d1
+    };
+
+    std::vector<wgpu::BindGroupEntry> entries = {
+        ggml_webgpu_make_tensor_bind_group_entry(ctx, 0, src1),
+        ggml_webgpu_make_tensor_bind_group_entry(ctx, 1, dst),
+    };
+    return ggml_backend_webgpu_build(ctx, pipeline, params, entries, wg_x, wg_y);
+}
